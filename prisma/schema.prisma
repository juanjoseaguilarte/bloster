generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  GESTOR
  EMPLEADO
  LIMPIEZA
}

enum ShiftType {
  TIME
  LIBRE
  OFF
  IMAGINARY
}

enum Period {
  MORNING
  AFTERNOON
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserGroup {
  BARRA
  COCINA
}

enum SalaryType {
  FIXED
  PER_SHIFT
  MIXED
}

enum PayrollStatus {
  DRAFT
  PAID
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(EMPLEADO)
  color        String    @default("#3B82F6")
  group        UserGroup @default(BARRA)
  active       Boolean   @default(true)
  payrollOnly  Boolean   @default(false)
  lastLoginAt     DateTime?
  pwaInstalledAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shifts         Shift[]
  closedWeeks    WeekSchedule[]   @relation("ClosedBy")
  clearedWeeks   WeekClearLog[]   @relation("ClearedBy")
  limpiezaCompletions LimpiezaCompletion[]
  pushSubs       PushSubscription[]
  salaryConfig   SalaryConfig?
  payrolls       MonthlyPayroll[]
  payrollsPaid   MonthlyPayroll[] @relation("PayrollPaidBy")
  exclusions     PayrollExclusion[]
}

model SalaryConfig {
  id            String     @id @default(cuid())
  userId        String     @unique
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          SalaryType @default(FIXED)
  fixedAmount   Float?
  morningRate   Float?
  afternoonRate Float?
  imaginaryRate Float?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model MonthlyPayroll {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  year           Int
  month          Int
  baseAmount     Float
  advances       Float         @default(0)
  garnishments   Float         @default(0)
  netAmount      Float
  transferAmount Float         @default(0)
  cashAmount     Float         @default(0)
  notes          String?
  status         PayrollStatus @default(DRAFT)
  paidAt         DateTime?
  paidById       String?
  paidBy         User?         @relation("PayrollPaidBy", fields: [paidById], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([userId, year, month])
}

model PayrollExclusion {
  id      String @id @default(cuid())
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  year    Int
  month   Int
  @@unique([userId, year, month])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

model WeekSchedule {
  id         String    @id @default(cuid())
  weekStart  DateTime  @unique
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedById String?
  closedBy   User?     @relation("ClosedBy", fields: [closedById], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shifts Shift[]
}

model Shift {
  id             String       @id @default(cuid())
  userId         String
  weekScheduleId String
  day            DayOfWeek
  period         Period
  type           ShiftType    @default(OFF)
  startTime      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  weekSchedule WeekSchedule @relation(fields: [weekScheduleId], references: [id])

  @@unique([userId, weekScheduleId, day, period])
}

model MonthSocialSecurity {
  id     String @id @default(cuid())
  year   Int
  month  Int
  amount Float  @default(0)
  @@unique([year, month])
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model WeekClearLog {
  id          String   @id @default(cuid())
  weekStart   DateTime
  clearedAt   DateTime @default(now())
  clearedById String?
  clearedBy   User?    @relation("ClearedBy", fields: [clearedById], references: [id])
  shifts      Json
}

model LimpiezaTask {
  id          String    @id @default(cuid())
  name        String
  section     UserGroup
  order       Int       @default(0)
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())

  completions LimpiezaCompletion[]
}

model LimpiezaCompletion {
  id          String       @id @default(cuid())
  taskId      String
  task        LimpiezaTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  dayOfWeek   DayOfWeek
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  completedAt DateTime     @default(now())

  @@unique([taskId, weekStart, dayOfWeek])
}
