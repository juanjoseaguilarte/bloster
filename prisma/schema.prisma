generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  GESTOR
  EMPLEADO
}

enum ShiftType {
  TIME
  LIBRE
  OFF
  IMAGINARY
}

enum Period {
  MORNING
  AFTERNOON
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum UserGroup {
  BARRA
  COCINA
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  passwordHash String
  role         Role      @default(EMPLEADO)
  color        String    @default("#3B82F6")
  group        UserGroup @default(BARRA)
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shifts         Shift[]
  closedWeeks    WeekSchedule[]  @relation("ClosedBy")
  clearedWeeks   WeekClearLog[]  @relation("ClearedBy")
}

model WeekSchedule {
  id         String    @id @default(cuid())
  weekStart  DateTime  @unique
  isClosed   Boolean   @default(false)
  closedAt   DateTime?
  closedById String?
  closedBy   User?     @relation("ClosedBy", fields: [closedById], references: [id])
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  shifts Shift[]
}

model Shift {
  id             String       @id @default(cuid())
  userId         String
  weekScheduleId String
  day            DayOfWeek
  period         Period
  type           ShiftType    @default(OFF)
  startTime      String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id])
  weekSchedule WeekSchedule @relation(fields: [weekScheduleId], references: [id])

  @@unique([userId, weekScheduleId, day, period])
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model WeekClearLog {
  id          String   @id @default(cuid())
  weekStart   DateTime
  clearedAt   DateTime @default(now())
  clearedById String?
  clearedBy   User?    @relation("ClearedBy", fields: [clearedById], references: [id])
  shifts      Json
}
